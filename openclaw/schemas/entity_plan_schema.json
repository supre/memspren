{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Stage 4b entity plan — structured vault write plan",
  "type": "object",
  "required": ["entities", "summary"],
  "additionalProperties": false,
  "properties": {
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "action", "content_draft"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative vault path, e.g. Work/Projects/memspren.md"
          },
          "action": {
            "type": "string",
            "enum": ["create", "append", "merge", "update"]
          },
          "content_draft": {
            "type": "string",
            "description": "Draft content for this entity. No wikilinks — linking directive adds those."
          },
          "node_type": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "string",
      "description": "Human-readable summary for the approval gate, e.g. '2 create, 1 append, 1 merge'"
    }
  }
}
